package com.example;

import java.lang.String;
import java.util.Objects;
import org.higherkindedj.hkt.nonemptylist.NonEmptyList;
import org.higherkindedj.hkt.validated.FieldError;
import org.higherkindedj.hkt.validated.Validated;
import org.higherkindedj.optics.annotations.Generated;

/**
 * Validated-assembly companion for {@link Customer}: one named method per component, in
 * declaration order; labels come from the component names; every error is
 * collected, located, and emerges in declaration order.
 */
@Generated
public final class CustomerAssembly {
  private CustomerAssembly() {
  }

  /**
   * Opens the assembly at the first component.
   */
  public static Stage0 fields() {
    return Stage0.INSTANCE;
  }

  /**
   * Stage 0 of 2: expects {@code name} next.
   */
  public static final class Stage0 {
    private static final Stage0 INSTANCE = new Stage0();

    private Stage0() {
    }

    /**
     * Supplies {@code name}; its errors are labelled {@code "name"}.
     */
    public Stage1 name(Validated<NonEmptyList<FieldError>, String> value) {
      Objects.requireNonNull(value, "value must not be null");
      return new Stage1(value.mapError(errors -> errors.map(err -> err.at("name"))));
    }
  }

  /**
   * Stage 1 of 2: expects {@code address} next.
   */
  public static final class Stage1 {
    private final Validated<NonEmptyList<FieldError>, String> name;

    private Stage1(Validated<NonEmptyList<FieldError>, String> name) {
      this.name = name;
    }

    /**
     * Supplies {@code address}; its errors are labelled {@code "address"}.
     */
    public Stage2 address(Validated<NonEmptyList<FieldError>, Address> value) {
      Objects.requireNonNull(value, "value must not be null");
      return new Stage2(this.name, value.mapError(errors -> errors.map(err -> err.at("address"))));
    }
  }

  /**
   * Terminal stage: every component supplied; {@code assemble()} only.
   */
  public static final class Stage2 {
    private final Validated<NonEmptyList<FieldError>, String> name;

    private final Validated<NonEmptyList<FieldError>, Address> address;

    private Stage2(Validated<NonEmptyList<FieldError>, String> name,
        Validated<NonEmptyList<FieldError>, Address> address) {
      this.name = name;
      this.address = address;
    }

    /**
     * Assembles the record via its canonical constructor; every error is collected, in
     * component-declaration order.
     */
    public Validated<NonEmptyList<FieldError>, Customer> assemble() {
      return this.address.ap(this.name.map(a1 -> a2 -> new Customer(a1, a2)), NonEmptyList.semigroup());
    }
  }
}
